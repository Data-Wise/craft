    def test_skills_have_frontmatter(self, project_root: Path):
        from helpers import extract_frontmatter, read_file
        skills_dir = project_root / "skills"
        missing = []
        for skill_file in sorted(skills_dir.rglob("SKILL.md")):
            fm = extract_frontmatter(read_file(skill_file))
            if "name" not in fm and "description" not in fm:
                missing.append(str(skill_file.relative_to(skills_dir)))
        assert not missing, f"Skills missing frontmatter: {missing}"
