import re
from pathlib import Path

import pytest

pytestmark = [pytest.mark.integration, pytest.mark.docs]


class TestBrokenLinks:
    """Check for broken internal links in documentation."""

    def test_no_broken_links(self, project_root: Path):
        """Verify all relative markdown links point to existing files."""
        broken = []
        docs_dir = project_root / "docs"
        if not docs_dir.exists():
            pytest.skip("No docs/ directory")

        for md_file in sorted(docs_dir.rglob("*.md")):
            content = md_file.read_text()
            # Match markdown links: [text](path.md) but not external URLs
            for match in re.finditer(r'\[([^\]]*)\]\(([^)]+)\)', content):
                link_target = match.group(2)
                if link_target.startswith(("http://", "https://", "#", "mailto:")):
                    continue
                # Strip anchors
                link_path = link_target.split("#")[0]
                if not link_path:
                    continue
                resolved = (md_file.parent / link_path).resolve()
                if not resolved.exists():
                    broken.append(f"{md_file.relative_to(project_root)}: {link_target}")

        assert not broken, f"Broken links: {broken}"


class TestMarkdownQuality:
    """Basic markdown quality checks."""

    def test_commands_have_headings(self, commands_dir: Path):
        """Every command file should have at least one heading."""
        no_headings = []
        for md_file in sorted(commands_dir.rglob("*.md")):
            content = md_file.read_text()
            if not re.search(r'^#+ ', content, re.MULTILINE):
                no_headings.append(str(md_file.relative_to(commands_dir)))
        assert not no_headings, f"Commands without headings: {no_headings}"
