class TestPluginValidation:
    """Validate plugin can be loaded and inspected."""

    def test_plugin_json_roundtrip(self, plugin_dir: Path):
        """plugin.json can be read, parsed, and re-serialized."""
        manifest = plugin_dir / "plugin.json"
        data = json.loads(manifest.read_text())
        roundtrip = json.loads(json.dumps(data))
