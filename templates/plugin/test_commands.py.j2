from pathlib import Path

import pytest

pytestmark = [pytest.mark.unit, pytest.mark.commands]


class TestCommandDiscovery:
    """Verify all commands are discoverable."""

    def test_command_count(self, commands_dir: Path):
        """Ensure expected number of command files exist."""
        md_files = list(commands_dir.rglob("*.md"))
        assert len(md_files) > 0, "No command files found"

    def test_no_empty_commands(self, commands_dir: Path):
        """No command file should be empty."""
        for md_file in sorted(commands_dir.rglob("*.md")):
            content = md_file.read_text()
            assert len(content.strip()) > 0, \
                f"Empty command file: {md_file.relative_to(commands_dir)}"


class TestCommandFrontmatter:
    """Validate YAML frontmatter in command files."""

    def test_all_commands_have_description(self, commands_dir: Path):
        from helpers import extract_frontmatter, read_file
        missing = []
        for md_file in sorted(commands_dir.rglob("*.md")):
            fm = extract_frontmatter(read_file(md_file))
            if "description" not in fm:
                missing.append(str(md_file.relative_to(commands_dir)))
        assert not missing, f"Commands missing description: {missing}"

    def test_arguments_have_names(self, commands_dir: Path):
        from helpers import extract_frontmatter, read_file
        bad = []
        for md_file in sorted(commands_dir.rglob("*.md")):
            fm = extract_frontmatter(read_file(md_file))
            for arg in fm.get("arguments", []):
                if "name" not in arg:
                    bad.append(str(md_file.relative_to(commands_dir)))
        assert not bad, f"Commands with unnamed arguments: {bad}"
