class TestOutputFormat:
    """Verify output formatting conventions."""

    def test_help_output_has_usage(self, cli_runner):
        result = cli_runner("--help")
        output = result.stdout.lower()
        assert "usage" in output or "{{ cli_name }}" in output

    def test_version_output_is_clean(self, cli_runner):
        result = cli_runner("--version")
        version = result.stdout.strip()
        # Version should be a single line
        assert "\n" not in version or len(version.splitlines()) <= 2


class TestStderrSeparation:
    """Verify stderr is used for errors, stdout for data."""

    def test_help_goes_to_stdout(self, cli_runner):
        result = cli_runner("--help")
        assert len(result.stdout) > 0

    def test_errors_go_to_stderr(self, cli_runner):
        result = cli_runner("--invalid-flag-xyz", expect_fail=True)
        # Errors should appear in stderr (or exit code nonzero)
        assert result.returncode != 0
